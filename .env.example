# Exact Online SDK Configuration
# Copy this file to .env and fill in your values

# Required
EXACT_DIVISION=your_division_here
EXACT_CLIENT_ID=your_client_id_here
EXACT_CLIENT_SECRET=your_client_secret_here
EXACT_REDIRECT_URI=https://localhost:8000/callback

# Optional - defaults shown
# EXACT_BASE_URL=https://start.exactonline.nl
# EXACT_AUTH_URL=https://start.exactonline.nl/api/oauth2/auth
# EXACT_TOKEN_URL=https://start.exactonline.nl/api/oauth2/token
# EXACT_TIMEOUT=30

# Optional - for encrypted token storage
# EXACT_ENCRYPTION_KEY=your_fernet_encryption_key_here

# Optional - custom token storage path (file-based)
# EXACT_TOKEN_PATH=/path/to/token/storage

# Optional - required for scripts/bootstrap_auth.py --mode listener (HTTPS listener)
# EXACT_LISTENER_CERT_PATH=/absolute/path/to/listener-cert.pem
# EXACT_LISTENER_KEY_PATH=/absolute/path/to/listener-key.pem

# Optional - custom user agent
# EXACT_USER_AGENT=exact-online-sdk/0.1.0 (+https://github.com/your-org/exact-online-sdk)
